# ============================================================
# AYRA — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/ayra"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Ollama ────────────────────────────────────────────────────
# Host for local Ollama instance
OLLAMA_HOST="http://localhost:11434"

# Default model to use
OLLAMA_DEFAULT_MODEL="llama3.2"

# ── Image Generation ─────────────────────────────────────────
# Stable Diffusion WebUI (A1111) — start with --api flag
SD_HOST="http://localhost:7860"

# ComfyUI
COMFY_HOST="http://localhost:8188"

# ── File Storage ──────────────────────────────────────────────
# Local uploads directory (relative to project root)
UPLOAD_DIR="./uploads"

# Max file size in bytes (default: 50MB)
MAX_FILE_SIZE="52428800"

# ── Neon Auth ─────────────────────────────────────────────────
# Copy from: Neon Console → your project → Auth tab → "Setup Guide"
NEON_AUTH_BASE_URL="https://your-project-id.auth.neon.tech"
NEON_AUTH_COOKIE_SECRET="change-to-32-char-random-string"
# Optional — set in Neon Console → Auth → Webhooks to secure the webhook
# NEON_AUTH_WEBHOOK_SECRET="another-random-secret"

# ── Optional: OpenAI-compatible fallback ────────────────────
# Uncomment to enable OpenAI API as fallback
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"
