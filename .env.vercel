# ============================================================
# AYRA — Vercel Environment Variables
# Paste these into: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================================

# ── REQUIRED: Database ───────────────────────────────────────
# Get from: neon.tech (free) or Vercel Postgres or Supabase
DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/ayra?sslmode=require"

# ── REQUIRED: Pick ONE AI provider ──────────────────────────

# Option 1 — Groq (fastest, generous free tier) → console.groq.com
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Option 2 — OpenRouter (100+ models, pay-per-use) → openrouter.ai
# OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Option 3 — OpenAI → platform.openai.com
# OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Option 4 — Self-hosted Ollama on a VPS
# OLLAMA_HOST="https://ollama.your-vps.com"

# ── OPTIONAL: File storage (Vercel Blob) ─────────────────────
# Get from: Vercel Dashboard → Storage → Create Blob Store
# Without this, file uploads are disabled on Vercel
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ── OPTIONAL: Image generation ──────────────────────────────
# Point to a hosted SD instance or leave empty to disable
# SD_HOST="https://sd.your-vps.com"
# COMFY_HOST="https://comfy.your-vps.com"

# ── App config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"

# ── Neon Auth ────────────────────────────────────────────────
# Neon Console → your project → Auth tab → copy these two values
NEON_AUTH_BASE_URL="https://your-project-id.auth.neon.tech"
NEON_AUTH_COOKIE_SECRET="generate-32-char-random-string"  # openssl rand -base64 32
