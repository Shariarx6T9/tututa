# ============================================================
# AYRA — Local Development Environment
# Copy this to .env.local (never commit .env.local to git)
# ============================================================

# ── Database (Docker) ─────────────────────────────────────────
DATABASE_URL="postgresql://ayra:ayra_local_password@localhost:5432/ayra"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── AI — LOCAL: Ollama ────────────────────────────────────────
# Make sure Ollama is running: ollama serve
OLLAMA_HOST="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="llama3.2"

# ── AI — CLOUD: uncomment ONE if you want cloud AI locally too
# GROQ_API_KEY="gsk_..."
# OPENROUTER_API_KEY="sk-or-v1-..."
# OPENAI_API_KEY="sk-..."

# ── Neon Auth — leave blank for local dev (auth is skipped)
# Fill these in once you enable Neon Auth in the Neon console:
# NEON_AUTH_BASE_URL="https://your-project.auth.neon.tech"
# NEON_AUTH_COOKIE_SECRET="run: openssl rand -base64 32"

# ── Image Generation ─────────────────────────────────────────
# Start SD WebUI with: python launch.py --api
SD_HOST="http://localhost:7860"
COMFY_HOST="http://localhost:8188"

# ── File Uploads ─────────────────────────────────────────────
# Local disk is used when BLOB_READ_WRITE_TOKEN is not set
MAX_FILE_SIZE="52428800"
